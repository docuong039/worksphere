generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  name               String
  password           String
  avatar             String?
  isAdministrator    Boolean         @default(false)
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  attachments        Attachment[]
  auditLogs          AuditLog[]
  comments           Comment[]
  notifications      Notification[]
  projectMemberships ProjectMember[]
  createdProjects    Project[]       @relation("ProjectCreator")
  queries            Query[]         @relation("QueryOwner")
  assignedTasks      Task[]          @relation("AssignedTasks")
  createdTasks       Task[]          @relation("CreatedTasks")
  timeLogs           TimeLog[]
  watchedTasks       Watcher[]

  @@index([email])
  @@index([isAdministrator])
  @@map("users")
}

model Role {
  id                  String               @id @default(cuid())
  name                String               @unique
  description         String?              @db.Text
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assignable          Boolean              @default(true)
  projectMembers      ProjectMember[]
  permissions         RolePermission[]
  trackers            RoleTracker[]
  workflowTransitions WorkflowTransition[]

  @@index([name])
  @@map("roles")
}

model RoleTracker {
  id        String   @id @default(cuid())
  roleId    String
  trackerId String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tracker   Tracker  @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@unique([roleId, trackerId])
  @@index([roleId])
  @@index([trackerId])
  @@map("role_trackers")
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?          @db.Text
  module      String
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@index([module])
  @@index([key])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Tracker {
  id                  String               @id @default(cuid())
  name                String               @unique
  description         String?              @db.Text
  position            Int                  @default(0)
  isDefault           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  projects            ProjectTracker[]
  roles               RoleTracker[]
  tasks               Task[]
  workflowTransitions WorkflowTransition[]

  @@index([position])
  @@map("trackers")
}

model ProjectTracker {
  id        String   @id @default(cuid())
  projectId String
  trackerId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tracker   Tracker  @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@unique([projectId, trackerId])
  @@index([projectId])
  @@index([trackerId])
  @@map("project_trackers")
}

model Status {
  id               String               @id @default(cuid())
  name             String               @unique
  description      String?              @db.Text
  position         Int                  @default(0)
  isClosed         Boolean              @default(false)
  isDefault        Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  defaultDoneRatio Int?
  tasks            Task[]
  workflowsFrom    WorkflowTransition[] @relation("FromStatus")
  workflowsTo      WorkflowTransition[] @relation("ToStatus")

  @@index([position])
  @@index([isClosed])
  @@map("statuses")
}

model Priority {
  id        String   @id @default(cuid())
  name      String   @unique
  position  Int      @default(0)
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@index([position])
  @@map("priorities")
}

model WorkflowTransition {
  id           String   @id @default(cuid())
  trackerId    String
  roleId       String?
  fromStatusId String
  toStatusId   String
  createdAt    DateTime @default(now())
  fromStatus   Status   @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  role         Role?    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  toStatus     Status   @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)
  tracker      Tracker  @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@unique([trackerId, roleId, fromStatusId, toStatusId])
  @@index([trackerId])
  @@index([roleId])
  @@index([fromStatusId])
  @@index([toStatusId])
  @@map("workflow_transitions")
}

model Project {
  id          String           @id @default(cuid())
  name        String
  description String?          @db.Text
  identifier  String           @unique
  startDate   DateTime?
  endDate     DateTime?
  isArchived  Boolean          @default(false)
  creatorId   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  isPublic    Boolean          @default(false)
  members     ProjectMember[]
  trackers    ProjectTracker[]
  creator     User             @relation("ProjectCreator", fields: [creatorId], references: [id])
  queries     Query[]
  tasks       Task[]
  timeLogs    TimeLog[]
  versions    Version[]

  @@index([identifier])
  @@index([creatorId])
  @@index([isArchived])
  @@index([isPublic])
  @@map("projects")
}

model ProjectMember {
  id                   String                     @id @default(cuid())
  projectId            String
  userId               String
  roleId               String
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  project              Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role                 Role                       @relation(fields: [roleId], references: [id])
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([roleId])
  @@map("project_members")
}


model Version {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  status      String    @default("open")
  dueDate     DateTime?
  projectId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tasks       Task[]
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@index([status])
  @@map("versions")
}

model Task {
  id             String          @id @default(cuid())
  title          String
  description    String?         @db.Text
  trackerId      String
  statusId       String
  priorityId     String
  projectId      String
  assigneeId     String?
  creatorId      String
  parentId       String?
  path           String?
  level          Int             @default(0)
  estimatedHours Float?
  dueDate        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  doneRatio      Int             @default(0)
  isPrivate      Boolean         @default(false)
  lockVersion    Int             @default(0)
  startDate      DateTime?
  versionId      String?
  number         Int             @unique @default(autoincrement())
  attachments    Attachment[]
  comments       Comment[]
  assignee       User?           @relation("AssignedTasks", fields: [assigneeId], references: [id])
  creator        User            @relation("CreatedTasks", fields: [creatorId], references: [id])
  parent         Task?           @relation("Subtasks", fields: [parentId], references: [id], onDelete: Restrict)
  subtasks       Task[]          @relation("Subtasks")
  priority       Priority        @relation(fields: [priorityId], references: [id])
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status         Status          @relation(fields: [statusId], references: [id])
  tracker        Tracker         @relation(fields: [trackerId], references: [id])
  version        Version?        @relation(fields: [versionId], references: [id])
  timeLogs       TimeLog[]
  watchers       Watcher[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([statusId])
  @@index([priorityId])
  @@index([trackerId])
  @@index([parentId])
  @@index([versionId])
  @@index([dueDate])
  @@index([isPrivate])
  @@map("tasks")
}


model Watcher {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("watchers")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  taskId    String
  createdAt DateTime @default(now())
  mimeType  String
  path      String
  size      Int
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("attachments")
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  userId    String
  metadata  String?  @db.LongText
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  changes    String?  @db.LongText
  userId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Query {
  id        String   @id @default(cuid())
  name      String
  projectId String?
  userId    String
  isPublic  Boolean  @default(false)
  filters   String   @db.Text
  columns   String?  @db.Text
  sortBy    String?
  sortOrder String?  @default("asc")
  groupBy   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation("QueryOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([isPublic])
  @@map("queries")
}

model TimeEntryActivity {
  id        String    @id @default(cuid())
  name      String    @unique
  position  Int       @default(0)
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  timeLogs  TimeLog[]

  @@index([position])
  @@map("time_entry_activities")
}

model TimeLog {
  id         String            @id @default(cuid())
  hours      Float
  comments   String?           @db.Text
  spentOn    DateTime
  userId     String
  taskId     String?
  projectId  String
  activityId String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  activity   TimeEntryActivity @relation(fields: [activityId], references: [id])
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?             @relation(fields: [taskId], references: [id])
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
  @@index([projectId])
  @@index([activityId])
  @@index([spentOn])
  @@map("time_logs")
}
